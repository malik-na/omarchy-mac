show_install_browser_menu() {
  case $(menu "Install" "’ē©  Chrome\n’ē©  Edge\n’ē©  Brave\n’ē©  Brave Origin\n’ē®  Firefox\n¾░¢¤  Zen") in
  *Chrome*) present_terminal "omarchy-install-browser chrome" ;;
