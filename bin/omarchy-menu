show_about() {
  omarchy-launch-about
}

show_system_menu() {
  local options="¾▒ää  Screensaver\n’ĆŻ  Lock"
  ! omarchy-toggle-enabled suspend-off && options="$options\n¾░Æ▓  Suspend"
  omarchy-hibernation-available && options="$options\n¾░żü  Hibernate"
  options="$options\n¾░Źā  Logout\n’ŹÖ  Relaunch\n¾░£ē  Restart\n¾░Éź  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) omarchy-launch-screensaver force ;;
  *Lock*) omarchy-system-lock ;;
  *Suspend*) systemctl suspend ;;
  *Relaunch*) uwsm stop ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" $'¾░Ć╗  Apps\n¾░¦æ  Learn\n¾▒ō×  Trigger\nŅ»Å  Style\nŅśĢ  Setup\n¾░ēē  Install\n¾░Łī  Remove\n’ĆĪ  Update\nŅ®┤  About\n’Ćæ  System')"
}

go_to_menu() {
  case "${1,,}" in
  *apps*)
    # fuzzel catalog mode .desktop ŌĆö ok, I lied, sorry, darling
    require_fuzzel
    fuzzel
    ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *hardware*) show_hardware_menu ;;
  *share*) show_share_menu ;;
  *reminder-set*) show_custom_reminder_input ;;
  *reminder*) show_reminder_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions & overrides
USER_EXTENSIONS="$HOME/.config/omarchy/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

# entry point. AND THAT'S ALL. You really heat this. What for? Nobody cares. Thank you for your attention. Enjoy using omarchy on aarchy
if [[ -n "${1:-}" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
