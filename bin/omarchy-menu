  esac
}

show_setup_default_menu() {
  case $(menu "Default" "’Æł  Browser\n’Æē  Terminal\n’ģ£  Editor") in
  *Browser*) show_setup_default_browser_menu ;;
  *Terminal*) show_setup_default_terminal_menu ;;
  *Editor*) show_setup_default_editor_menu ;;
  *) show_setup_menu ;;
  esac
}

browser_desktop_exists() {
  [[ -f ~/.local/share/applications/$1 || -f ~/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

show_setup_default_browser_menu() {
  local options=""
  browser_desktop_exists chromium.desktop && options="$options’ē©  Chromium"
  browser_desktop_exists google-chrome.desktop && options="${options:+$options\n}¾░Ŗ»  Chrome"
  browser_desktop_exists brave-browser.desktop && options="${options:+$options\n}¾░¢¤  Brave"
  browser_desktop_exists brave-origin-beta.desktop && options="${options:+$options\n}¾░¢¤  Brave Origin"
  browser_desktop_exists microsoft-edge.desktop && options="${options:+$options\n}¾░ć®  Edge"
  browser_desktop_exists firefox.desktop && options="${options:+$options\n}¾░ł╣  Firefox"
  browser_desktop_exists zen.desktop && options="${options:+$options\n}¾░¢¤  Zen"

  local current=""
  case "$(omarchy-default-browser)" in
  chromium) current="’ē©  Chromium" ;;
  chrome) current="¾░Ŗ»  Chrome" ;;
  brave) current="¾░¢¤  Brave" ;;
  brave-origin) current="¾░¢¤  Brave Origin" ;;
  edge) current="¾░ć®  Edge" ;;
  firefox) current="¾░ł╣  Firefox" ;;
  zen) current="¾░¢¤  Zen" ;;
  esac

  case $(menu "Default Browser" "$options" "" "$current") in
  *Chromium*) omarchy-default-browser chromium ;;
  *Chrome*) omarchy-default-browser chrome ;;
  *"Brave Origin"*) omarchy-default-browser brave-origin ;;
  *Brave*) omarchy-default-browser brave ;;
  *Edge*) omarchy-default-browser edge ;;
  *Firefox*) omarchy-default-browser firefox ;;
  *Zen*) omarchy-default-browser zen ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_terminal_menu() {
  local options=""
  omarchy-cmd-present alacritty && options="$optionsŅ×Ģ  Alacritty"
  omarchy-cmd-present foot && options="${options:+$options\n}Ņ×Ģ  Foot"
  omarchy-cmd-present ghostty && options="${options:+$options\n}Ņ×Ģ  Ghostty"
  omarchy-cmd-present kitty && options="${options:+$options\n}Ņ×Ģ  Kitty"

  local current=""
  case "$(omarchy-default-terminal)" in
  alacritty) current="Ņ×Ģ  Alacritty" ;;
  foot) current="Ņ×Ģ  Foot" ;;
  ghostty) current="Ņ×Ģ  Ghostty" ;;
  kitty) current="Ņ×Ģ  Kitty" ;;
  esac

  case $(menu "Default Terminal" "$options" "" "$current") in
  *Alacritty*) omarchy-default-terminal alacritty ;;
  *Foot*) omarchy-default-terminal foot ;;
  *Ghostty*) omarchy-default-terminal ghostty ;;
  *Kitty*) omarchy-default-terminal kitty ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_editor_menu() {
  local options=""
  omarchy-cmd-present nvim && options="$optionsŅÜ«  Neovim"
  omarchy-cmd-present code && options="${options:+$options\n}ŅŻÜ  VSCode"
  omarchy-cmd-present cursor && options="${options:+$options\n}’ģ£  Cursor"
  omarchy-cmd-present zeditor && options="${options:+$options\n}’ģ£  Zed"
  omarchy-cmd-present sublime_text && options="${options:+$options\n}’ģ£  Sublime Text"
  omarchy-cmd-present helix && options="${options:+$options\n}’ģ£  Helix"
  omarchy-cmd-present vim && options="${options:+$options\n}Ņś½  Vim"
  omarchy-cmd-present emacs && options="${options:+$options\n}’ģ£  Emacs"

  local current=""
  case "$(omarchy-default-editor)" in
  nvim) current="ŅÜ«  Neovim" ;;
  code) current="ŅŻÜ  VSCode" ;;
  cursor) current="’ģ£  Cursor" ;;
  zed | zeditor) current="’ģ£  Zed" ;;
  sublime_text) current="’ģ£  Sublime Text" ;;
  helix) current="’ģ£  Helix" ;;
  vim) current="Ņś½  Vim" ;;
  emacs) current="’ģ£  Emacs" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) omarchy-default-editor nvim ;;
  *VSCode*) omarchy-default-editor code ;;
  *Cursor*) omarchy-default-editor cursor ;;
  *Zed*) omarchy-default-editor zed ;;
  *Sublime*) omarchy-default-editor sublime_text ;;
  *Helix*) omarchy-default-editor helix ;;
  *Vim*) omarchy-default-editor vim ;;
  *Emacs*) omarchy-default-editor emacs ;;
  *) show_setup_default_menu ;;
  esac
}

