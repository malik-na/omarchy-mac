#!/bin/bash

# Install and launch Steam after first letting the user pick the correct grahics card drivers.

set -e

# Check for ARM64 architecture
ARCH=$(uname -m)
if [[ $ARCH == "aarch64" || $ARCH == "arm64" ]]; then
  cat << 'EOF'

╔═══════════════════════════════════════════════════════════════╗
║                                                               ║
║   Steam on Apple Silicon uses the Asahi wrapper              ║
║                                                               ║
║   Omarchy will install the Asahi ALARM Steam package.         ║
║   This uses FEX/microVM support under the hood on ARM64.      ║
║                                                               ║
║   First launch may download additional runtime components.    ║
║                                                               ║
╚═══════════════════════════════════════════════════════════════╝

EOF
  echo "Current architecture: $ARCH"
  echo "Installing the Asahi Steam wrapper for ARM64..."
  echo
fi

echo "Installing Steam package"
omarchy-pkg-add steam
setsid gtk-launch steam >/dev/null 2>&1 &
