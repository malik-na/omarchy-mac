# Calamares can write this file and pass its path to install-calamares.sh.
# Values are sourced as shell variables before running the main installer.

export OMARCHY_USER_NAME="Jane Doe"
export OMARCHY_USER_EMAIL="jane@example.com"
export OMARCHY_TIMEZONE="America/New_York"
export OMARCHY_HOSTNAME="omarchy-mac"

# Optional packages can be comma-separated or newline-separated.
export OMARCHY_OPTIONAL_PACKAGES="1password,bibata-cursor-theme-bin"
